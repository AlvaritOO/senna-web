---
import Base from '../../layouts/Base.astro';
import { UNIDADES, porSlug } from '../../data/unidades.ts';

// Prerendera una página estática por unidad (excelente para SEO).
export function getStaticPaths() {
  return UNIDADES.map((u) => ({ params: { slug: u.slug } }));
}

const { slug } = Astro.params;
const u = porSlug(slug);
if (!u) return Astro.redirect('/');
const wpp = import.meta.env.PUBLIC_WHATSAPP ?? '56966078526';
const consulta = encodeURIComponent(`Hola, me interesa la unidad ${u.nombre}. ¿Disponibilidad?`);
---
<Base titulo={`${u.nombre} — Senna`} descripcion={u.resumen}>
  <article class="ficha">
    <div class="contenedor">
      <a href="/#unidades" class="volver">← Todas las unidades</a>

      <header class="ficha__head">
        <span class="ficha__num">{u.numero}</span>
        <div>
          <h1>{u.nombre}</h1>
          <p class="ficha__ubic">{u.ubicacion}</p>
        </div>
      </header>

      <div class="ficha__hero">
        <img src={u.destacada.src} alt={u.destacada.alt} loading="eager" />
      </div>

      <div class="ficha__grid">
        <div class="ficha__cuerpo">
          <p class="ficha__resumen">{u.resumen}</p>
          <h2>Amenidades</h2>
          <ul class="ficha__amen">
            {u.amenidades.map((a) => <li>{a}</li>)}
          </ul>
        </div>

        <aside class="ficha__panel">
          <div class="ficha__precio">
            <strong>{u.precio.monto}</strong><span>{u.precio.nota}</span>
          </div>
          <dl class="ficha__datos">
            <div><dt>Distribución</dt><dd>{u.distribucion}</dd></div>
            <div><dt>Equipamiento</dt><dd>{u.equipamiento}</dd></div>
            <div><dt>Estadía mínima</dt><dd>{u.estadiaMinima}</dd></div>
          </dl>
          <a class="boton" href={`https://wa.me/${wpp}?text=${consulta}`}>Consultar disponibilidad</a>
        </aside>
      </div>

      <h2 class="ficha__galh">Galería</h2>
      <div class="ficha__galeria">
        {u.galeria.map((g) => <img src={g.src} alt={g.alt} loading="lazy" />)}
      </div>
    </div>
  </article>

  <style>
    .ficha { padding: 40px 0 0; }
    .volver { color: var(--acero); font-size: 14px; }
    .volver:hover { color: var(--oro); }
    .ficha__head { display: flex; align-items: flex-end; gap: 20px; margin: 24px 0 28px; }
    .ficha__num { font-family: var(--fuente-display); font-size: 80px; line-height: 0.8; color: var(--oro); }
    .ficha__head h1 { font-size: clamp(32px, 5vw, 52px); margin: 0; }
    .ficha__ubic { color: var(--acero); margin: 6px 0 0; }
    .ficha__hero img { width: 100%; height: 460px; object-fit: cover; border-radius: var(--radio); border: 1px solid var(--linea); }
    @media (max-width: 720px) { .ficha__hero img { height: 280px; } }

    .ficha__grid { display: grid; grid-template-columns: 1.6fr 0.9fr; gap: 48px; margin: 48px 0; align-items: start; }
    @media (max-width: 820px) { .ficha__grid { grid-template-columns: 1fr; } }
    .ficha__resumen { font-size: 19px; color: var(--marfil); margin: 0 0 32px; }
    .ficha__cuerpo h2 { font-size: 26px; margin: 0 0 16px; }
    .ficha__amen { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 10px 24px; }
    @media (max-width: 560px) { .ficha__amen { grid-template-columns: 1fr; } }
    .ficha__amen li { padding-left: 22px; position: relative; color: var(--acero); }
    .ficha__amen li::before { content: '✓'; position: absolute; left: 0; color: var(--oro); }

    .ficha__panel { background: var(--profundo); border: 1px solid var(--linea); border-radius: var(--radio); padding: 28px 26px; position: sticky; top: 88px; }
    .ficha__precio { display: flex; align-items: baseline; gap: 8px; padding-bottom: 20px; border-bottom: 1px solid var(--linea); margin-bottom: 20px; }
    .ficha__precio strong { font-family: var(--fuente-display); font-size: clamp(30px, 5vw, 44px); color: var(--oro); }
    .ficha__precio span { color: var(--acero); font-size: 14px; }
    .ficha__datos { margin: 0 0 24px; display: grid; gap: 14px; }
    .ficha__datos dt { font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--acero); }
    .ficha__datos dd { margin: 2px 0 0; }
    .ficha__panel .boton { width: 100%; justify-content: center; }

    .ficha__galh { font-size: 26px; margin: 16px 0 20px; }
    .ficha__galeria { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; padding-bottom: 24px; }
    @media (max-width: 720px) { .ficha__galeria { grid-template-columns: 1fr 1fr; } }
    .ficha__galeria img { width: 100%; height: 200px; object-fit: cover; border-radius: var(--radio); border: 1px solid var(--linea); }
  </style>
</Base>
